---
import { render, type CollectionEntry } from "astro:content";
import EntryLayout from "../../layouts/EntryLayout.astro";
import {
  buildCareerLinks,
  buildCareerMeta,
  buildCareerTitleParts,
  getCareerEntries,
  toEntrySlug,
} from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getCareerEntries();

  return entries.map((entry) => ({
    params: { slug: toEntrySlug(entry) },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"career">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const titleParts = buildCareerTitleParts(entry);
---

<EntryLayout
  title={entry.data.title}
  titleParts={titleParts}
  description={entry.data.summary}
  summary={entry.data.summary}
  meta={buildCareerMeta(entry)}
  backHref="/career/"
  backLabel="career"
  links={buildCareerLinks(entry)}
>
  <Content />
</EntryLayout>
