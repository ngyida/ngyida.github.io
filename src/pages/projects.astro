---
import { render } from "astro:content";
import ProsePageLayout from "../layouts/ProsePageLayout.astro";
import {
  buildProjectLinks,
  buildProjectMeta,
  getPageEntry,
  getProjectGroup,
  getProjectEntries,
  toCollectionHref,
  toEntrySlug,
} from "../lib/content";

const page = await getPageEntry("projects");
const entries = await getProjectEntries();
const coolEntries = entries.filter((entry) => getProjectGroup(entry) === "cool");
const notCoolEntries = entries.filter((entry) => getProjectGroup(entry) === "not-cool");
const { Content } = await render(page);
---

<ProsePageLayout
  title={page.data.title}
  description={page.data.description}
  intro={page.data.intro}
>
  <Content />

  <hr />
  <h2>cool projects</h2>

  <ol class="entry-list">
    {
      coolEntries.map((entry) => (
        <li>
          <h3 class="entry-list-title">
            <a href={toCollectionHref("projects", toEntrySlug(entry))}>{entry.data.title}</a>
          </h3>
          <p class="entry-list-meta">{buildProjectMeta(entry)}</p>
          <p class="entry-list-summary">{entry.data.listBlurb}</p>
          {
            buildProjectLinks(entry).length > 0 && (
              <div class="inline-links">
                {buildProjectLinks(entry).map((link) => (
                  <a href={link.url} target="_blank" rel="noreferrer">
                    {link.label}
                  </a>
                ))}
              </div>
            )
          }
        </li>
      ))
    }
  </ol>

  <hr />

  <details class="project-collapsible">
    <summary>not-cool projects</summary>
    {
      notCoolEntries.length > 0 ? (
        <ol class="entry-list">
          {
            notCoolEntries.map((entry) => (
              <li>
                <h3 class="entry-list-title">
                  <a href={toCollectionHref("projects", toEntrySlug(entry))}>
                    {entry.data.title}
                  </a>
                </h3>
                <p class="entry-list-meta">{buildProjectMeta(entry)}</p>
                <p class="entry-list-summary">{entry.data.listBlurb}</p>
                {
                  buildProjectLinks(entry).length > 0 && (
                    <div class="inline-links">
                      {buildProjectLinks(entry).map((link) => (
                        <a href={link.url} target="_blank" rel="noreferrer">
                          {link.label}
                        </a>
                      ))}
                    </div>
                  )
                }
              </li>
            ))
          }
        </ol>
      ) : (
        <p class="project-collapsible-empty">No not-cool projects yet.</p>
      )
    }
  </details>
</ProsePageLayout>
