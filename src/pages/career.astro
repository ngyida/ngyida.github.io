---
import { render } from "astro:content";
import ProsePageLayout from "../layouts/ProsePageLayout.astro";
import {
  buildCareerMeta,
  getCareerEntries,
  getPageEntry,
  toCollectionHref,
  toEntrySlug,
} from "../lib/content";

const page = await getPageEntry("career");
const entries = await getCareerEntries();
const { Content } = await render(page);
---

<ProsePageLayout
  title={page.data.title}
  description={page.data.description}
  intro={page.data.intro}
>
  <Content />

  <hr />
  <h2>Endeavors</h2>

  <ul class="entry-list career-entry-list">
    {
      entries.map((entry) => (
        <li class="career-entry-item">
          <div class="career-entry-head">
            <h3 class="entry-list-title">
              <a href={toCollectionHref("career", toEntrySlug(entry))}>{entry.data.title}</a>
            </h3>
            <p class="entry-list-meta">{buildCareerMeta(entry)}</p>
          </div>
          <p class="entry-list-summary">{entry.data.summary}</p>
        </li>
      ))
    }
  </ul>
</ProsePageLayout>
